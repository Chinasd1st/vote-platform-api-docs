    {
      "name": "Notifications",
      "item": [
        {
          "name": "获取通知列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/notifications?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["notifications"],
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        },
        {
          "name": "标记全部已读",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/notifications",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"markAll\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "获取登录设备",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sessions"
          }
        },
        {
          "name": "删除所有其他设备",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/sessions"
          }
        }
      ]
    },
    {
      "name": "Topics",
      "item": [
        {
          "name": "获取所有主题",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/topics"
          }
        }
      ]
    },
    {
      "name": "Bookmarks",
      "item": [
        {
          "name": "获取收藏列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookmarks"
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "提交举报",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/reports",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetType\": \"post\",\n  \"targetId\": \"target-id-here\",\n  \"reason\": \"spam\",\n  \"description\": \"垃圾信息\"\n}"
            }
          }
        },
        {
          "name": "检查是否已举报",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports/check?targetType=post&targetId=xxx",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "check"],
              "query": [
                { "key": "targetType", "value": "post" },
                { "key": "targetId", "value": "xxx" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ostracism",
      "item": [
        {
          "name": "获取放逐提案列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ostracism?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["ostracism"],
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        },
        {
          "name": "发起放逐提案",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ostracism",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetId\": \"user-id-here\",\n  \"reason\": \"该用户多次违反社区规则，发布不当内容\"\n}"
            }
          }
        },
        {
          "name": "获取提案详情",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ostracism/{{proposalId}}"
          }
        },
        {
          "name": "附议提案",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ostracism/{{proposalId}}/second"
          }
        },
        {
          "name": "提交自辩",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ostracism/{{proposalId}}/defense",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defense\": \"我对相关情况进行说明...\"\n}"
            }
          }
        },
        {
          "name": "投票",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ostracism/{{proposalId}}/vote",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vote\": \"for\"\n}"
            }
          }
        }
      ]
