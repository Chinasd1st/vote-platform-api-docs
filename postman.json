{
  "info": {
    "name": "恶俗投票平台 API",
    "description": "恶俗投票平台 OpenAPI 接口集合 v1.14.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://votehub.silentnrtx.top/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "登录",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@vote.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "注册",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"测试用户\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Pass1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Polls",
      "item": [
        {
          "name": "获取投票列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/polls?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["polls"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "创建投票",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/polls",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"你最喜欢的编程语言？\",\n  \"description\": \"投票选择最常用的编程语言\",\n  \"options\": [\"TypeScript\", \"JavaScript\", \"Rust\", \"Go\"],\n  \"type\": \"single\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "获取投票详情",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/polls/{{pollId}}"
          }
        },
        {
          "name": "更新投票",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/polls/{{pollId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"更新后的标题\"\n}"
            }
          }
        },
        {
          "name": "删除投票",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/polls/{{pollId}}"
          }
        },
        {
          "name": "克隆投票",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/polls/{{pollId}}/clone"
          }
        },
        {
          "name": "导出 CSV",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/polls/{{pollId}}/export"
          }
        },
        {
          "name": "分享计数",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/polls/{{pollId}}/share"
          }
        },
        {
          "name": "切换收藏",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/polls/{{pollId}}/bookmark"
          }
        },
        {
          "name": "获取收藏状态",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/polls/{{pollId}}/bookmark"
          }
        }
      ]
    },
    {
      "name": "Votes",
      "item": [
        {
          "name": "获取投票记录",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/polls/{{pollId}}/vote"
          }
        },
        {
          "name": "提交单选投票",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/polls/{{pollId}}/vote",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"optionId\": \"option-id-here\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Poll Comments",
      "item": [
        {
          "name": "获取评论列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/polls/{{pollId}}/comments?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["polls", "{{pollId}}", "comments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "发表评论",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/polls/{{pollId}}/comments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"这是一条评论\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "获取推文列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "发表推文",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"分享一个有趣的投票 #投票 #编程\"\n}"
            }
          }
        },
        {
          "name": "获取推文详情",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/{{postId}}"
          }
        },
        {
          "name": "更新推文",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/posts/{{postId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"更新后的推文内容\"\n}"
            }
          }
        },
        {
          "name": "删除推文",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/posts/{{postId}}"
          }
        },
        {
          "name": "点赞",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts/{{postId}}/likes"
          }
        },
        {
          "name": "取消点赞",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/posts/{{postId}}/likes"
          }
        }
      ]
    },
    {
      "name": "Post Comments",
      "item": [
        {
          "name": "获取评论列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}/comments?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}", "comments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "发表评论",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts/{{postId}}/comments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"这是一条评论\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "获取当前用户资料",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile"
          }
        },
        {
          "name": "更新个人资料",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"个人简介\"\n}"
            }
          }
        },
        {
          "name": "修改密码",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/profile/password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"oldpass123\",\n  \"newPassword\": \"Newpass123\"\n}"
            }
          }
        },
        {
          "name": "获取用户公开资料",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile/{{userId}}"
          }
        },
        {
          "name": "获取粉丝列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile/{{userId}}/followers"
          }
        },
        {
          "name": "获取关注列表",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile/{{userId}}/following"
          }
        },
        {
          "name": "获取投票历史",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/profile/{{userId}}/votes?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["profile", "{{userId}}", "votes"],
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        }
      ]
    },
    {
      "name": "Follows",
      "item": [
        {
          "name": "关注用户",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/follows/{{userId}}"
          }
        },
        {
          "name": "取消关注",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/follows/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Blocks",
      "item": [
        {
          "name": "获取屏蔽列表",
