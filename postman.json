          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/reports/{{reportId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"ban\",\n  \"banDays\": 7,\n  \"banReason\": \"违反社区规则\"\n}"
            }
          }
        },
        {
          "name": "获取封禁列表",
          "request": {
            "method": "GET",
            "url": {
